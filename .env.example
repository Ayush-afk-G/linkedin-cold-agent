# Google Sheets credentials (service account JSON file path)
# GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# Google Sheets spreadsheet ID (from the URL: /spreadsheets/d/<ID>/)
# SPREADSHEET_ID=

# Name of the source tab to read leads from
# SOURCE_SHEET_NAME=ClayData.csv

# Name of the output tab to write results to
# OUTPUT_SHEET_NAME=Leads_Personalized

# Gemini API key
# GEMINI_API_KEY=

# Gemini model to use
# GEMINI_MODEL=gemini-3-flash-preview

# HeyReach API key
# HEYREACH_API_KEY=

# HeyReach list ID to add leads to
# HEYREACH_LIST_ID=

# Number of leads to process per batch
# BATCH_SIZE=5

# Seconds to wait between API calls to respect rate limits
# RATE_LIMIT_DELAY=2.0

# Exclusion list — leads from these companies will be skipped
# EXCLUSION_SPREADSHEET_ID=
# EXCLUSION_SHEET_NAME=Reality